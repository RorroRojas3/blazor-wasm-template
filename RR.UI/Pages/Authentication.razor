@page "/authentication/{action}"

<RemoteAuthenticatorView Action="@Action">
    <LogInFailed>
        <div class="app-loading">
            <div class="app-loading-error">
                <h4>Login Failed</h4>
                <p>An error occurred during authentication. Please try again.</p>
                <a href="/" class="btn btn-outline-light">Return Home</a>
            </div>
        </div>
    </LogInFailed>
    <LoggingIn>
        <div class="app-loading">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="app-loading-status">Signing you in...</span>
        </div>
    </LoggingIn>
    <LogOut>
        <div class="app-loading">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="app-loading-status">Signing you out...</span>
        </div>
    </LogOut>
    <CompletingLoggingIn>
        <div class="app-loading">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="app-loading-status">Completing sign-in...</span>
        </div>
    </CompletingLoggingIn>
    <CompletingLogOut>
        <div class="app-loading">
            <div class="spinner-border text-light" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <span class="app-loading-status">Completing sign-out...</span>
        </div>
    </CompletingLogOut>
</RemoteAuthenticatorView>

@code {
    [Parameter]
    public string? Action { get; set; }
}
